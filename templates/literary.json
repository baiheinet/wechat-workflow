{
  "name": "literary",
  "label": "文艺风格",
  "styles": {
    "body": "font-size:16px;line-height:1.8;color:#3e3a39;font-family:Georgia,'Noto Serif SC','Source Han Serif SC',serif;letter-spacing:1px;",
    "h1": "font-size:22px;font-weight:700;color:#8b6f47;margin:28px 0 14px;line-height:1.5;text-align:center;",
    "h2": "font-size:19px;font-weight:600;color:#8b6f47;margin:22px 0 12px;line-height:1.5;border-bottom:1px solid #e8ddd0;padding-bottom:6px;",
    "h3": "font-size:17px;font-weight:600;color:#6b5a48;margin:18px 0 10px;line-height:1.5;",
    "h4": "font-size:16px;font-weight:600;color:#6b5a48;margin:14px 0 8px;line-height:1.5;",
    "p": "font-size:16px;line-height:1.8;color:#3e3a39;margin:0 0 14px;text-indent:0;",
    "strong": "font-weight:700;color:#8b6f47;",
    "em": "font-style:italic;color:#7a6b5e;",
    "del": "text-decoration:line-through;color:#b8a99a;",
    "a": "color:#8b6f47;text-decoration:none;border-bottom:1px dotted #c4b5a6;",
    "blockquote": "border-left:3px solid #c4b5a6;padding:10px 18px;margin:14px 0;color:#6b5a48;background:#f8f4ee;border-radius:0 4px 4px 0;font-style:italic;",
    "code": "font-size:14px;background:#ede8e0;padding:2px 6px;border-radius:3px;font-family:Menlo,monospace;color:#8b6f47;",
    "pre": "background:#f8f4ee;padding:14px 18px;border-radius:4px;overflow-x:auto;margin:14px 0;font-size:14px;line-height:1.6;border:1px solid #e8ddd0;",
    "pre_code": "background:transparent;padding:0;border-radius:0;color:#5a4a3a;font-size:14px;font-family:Menlo,monospace;",
    "ul": "margin:10px 0;padding-left:24px;list-style-type:circle;",
    "ol": "margin:10px 0;padding-left:24px;",
    "li": "font-size:16px;line-height:1.8;color:#3e3a39;margin:4px 0;",
    "img": "max-width:100%;height:auto;display:block;margin:16px auto;border-radius:4px;box-shadow:0 4px 16px rgba(0,0,0,0.08);",
    "hr": "border:none;border-top:1px solid #e8ddd0;margin:28px 0;",
    "table": "width:100%;border-collapse:collapse;margin:14px 0;font-size:15px;",
    "th": "background:#ede8e0;padding:8px 12px;border:1px solid #d6c9ba;font-weight:600;text-align:left;color:#6b5a48;",
    "td": "padding:8px 12px;border:1px solid #d6c9ba;text-align:left;"
  }
}
