{
  "name": "minimal",
  "label": "简约风格",
  "styles": {
    "body": "font-size:15px;line-height:1.75;color:#333;font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;letter-spacing:0.5px;",
    "h1": "font-size:22px;font-weight:700;color:#222;margin:24px 0 12px;line-height:1.5;",
    "h2": "font-size:19px;font-weight:700;color:#222;margin:20px 0 10px;line-height:1.5;",
    "h3": "font-size:17px;font-weight:600;color:#333;margin:16px 0 8px;line-height:1.5;",
    "h4": "font-size:15px;font-weight:600;color:#444;margin:12px 0 6px;line-height:1.5;",
    "p": "font-size:15px;line-height:1.75;color:#333;margin:0 0 12px;",
    "strong": "font-weight:700;color:#222;",
    "em": "font-style:italic;",
    "del": "text-decoration:line-through;color:#999;",
    "a": "color:#1a73e8;text-decoration:none;",
    "blockquote": "border-left:3px solid #ddd;padding:8px 16px;margin:12px 0;color:#666;background:#f9f9f9;",
    "code": "font-size:13px;background:#f0f0f0;padding:2px 6px;border-radius:3px;font-family:Menlo,Monaco,monospace;color:#c7254e;",
    "pre": "background:#f5f5f5;padding:12px 16px;border-radius:4px;overflow-x:auto;margin:12px 0;font-size:13px;line-height:1.5;",
    "pre_code": "background:transparent;padding:0;border-radius:0;color:#333;font-size:13px;",
    "ul": "margin:8px 0;padding-left:20px;",
    "ol": "margin:8px 0;padding-left:20px;",
    "li": "font-size:15px;line-height:1.75;color:#333;margin:4px 0;",
    "img": "max-width:100%;height:auto;display:block;margin:12px auto;border-radius:4px;",
    "hr": "border:none;border-top:1px solid #eee;margin:24px 0;",
    "table": "width:100%;border-collapse:collapse;margin:12px 0;font-size:14px;",
    "th": "background:#f5f5f5;padding:8px 12px;border:1px solid #ddd;font-weight:600;text-align:left;",
    "td": "padding:8px 12px;border:1px solid #ddd;text-align:left;"
  }
}
